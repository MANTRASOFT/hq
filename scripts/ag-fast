#!/bin/bash

# AgendaFleet CLI - Fast Production Wrapper
# Uses esbuild bundle for ecosystem commands, ts-node for ag cli commands

CLI_DIR="/home/pascal/projects/agenda-fleet/agenda-cli"

# Check if first argument is 'cli' - use ts-node for development commands
if [ "$1" = "cli" ]; then
    # ag cli commands need ts-node for autogenerated code
    cd "$CLI_DIR" && exec npx ts-node -r tsconfig-paths/register --project "$CLI_DIR/tsconfig.json" --transpile-only "$CLI_DIR/src/index.ts" "$@"
fi

# Check if ecosystem bundle exists
if [ ! -f "$CLI_DIR/dist/ag-ecosystem.js" ]; then
    echo "Error: Ecosystem bundle not found. Run: npm run build:fast"
    exit 1
fi

# Use ecosystem bundle for fast startup (<1s)
# Includes: ag query, ag sudo, ag completion, ag projects, ag doc
exec node -r tsconfig-paths/register "$CLI_DIR/dist/ag-ecosystem.js" "$@"
