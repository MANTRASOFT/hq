#!/bin/bash

# AgendaFleet CLI - Fast Wrapper with Environment Caching
# Caches validation results in ~/.ag/env-cache for speed

# Load nvm and use Node 20 (required for firebase-admin)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
nvm use 20 > /dev/null 2>&1

# Define paths
CLI_DIR="/home/pascal/projects/agenda-fleet/agenda-cli"

# Set NODE_PATH to include project node_modules and global modules
# Project modules take priority so we use dependencies from package.json
export NODE_PATH="$CLI_DIR/node_modules:$(npm root -g):$NODE_PATH"
AG_DIR="$HOME/.ag"
ENV_CACHE="$AG_DIR/env-cache"
CACHE_DURATION=3600  # 1 hour in seconds

# Ensure .ag directory exists
mkdir -p "$AG_DIR"

# Ensure project dependencies are installed
if [ ! -d "$CLI_DIR/node_modules" ]; then
    echo "📦 Installing project dependencies..."
    cd "$CLI_DIR" && npm install
fi

# Check if cache is valid (modified within last hour)
cache_valid() {
    if [ -f "$ENV_CACHE" ]; then
        local cache_age=$(( $(date +%s) - $(stat -c %Y "$ENV_CACHE" 2>/dev/null || stat -f %m "$ENV_CACHE" 2>/dev/null || echo 0) ))
        [ "$cache_age" -lt "$CACHE_DURATION" ]
    else
        return 1
    fi
}

# Validate environment and cache results
if ! cache_valid; then
    # Cache is stale or missing - run validation

    # Check Node version
    NODE_VERSION=$(node --version 2>/dev/null || echo "v0")
    if [[ "$NODE_VERSION" =~ ^v(18|20|22)\. ]]; then
        NODE_STATUS="✓ Node $NODE_VERSION"
    else
        NODE_STATUS="⚠ Node $NODE_VERSION (18/20 recommended)"
    fi

    # Check optional tools (don't block, just inform)
    FIREBASE_STATUS="✗ Not installed"
    if command -v firebase >/dev/null 2>&1; then
        FIREBASE_VERSION=$(firebase --version 2>/dev/null | head -1 || echo "unknown")
        FIREBASE_STATUS="✓ firebase-tools $FIREBASE_VERSION"
    fi

    GCLOUD_STATUS="✗ Not installed"
    if command -v gcloud >/dev/null 2>&1; then
        GCLOUD_STATUS="✓ gcloud CLI"
    fi

    GH_STATUS="✗ Not installed"
    if command -v gh >/dev/null 2>&1; then
        GH_STATUS="✓ GitHub CLI"
    fi

    # Write cache file
    cat > "$ENV_CACHE" <<EOF
# AG CLI Environment Cache
# Generated: $(date)
# Valid for: $CACHE_DURATION seconds

NODE_VERSION=$NODE_VERSION
NODE_STATUS=$NODE_STATUS
FIREBASE_STATUS=$FIREBASE_STATUS
GCLOUD_STATUS=$GCLOUD_STATUS
GH_STATUS=$GH_STATUS
EOF
fi

# Environment is validated (from cache or fresh check)

# Smart routing based on command type
# - ag cli commands: Use ts-node (needs autogenerated code access)
# - Ecosystem commands: Use esbuild bundle (fast <2s startup)

if [ "$1" = "cli" ]; then
    # ag cli commands need ts-node for functions/ directory access
    cd "$CLI_DIR" && exec npx ts-node -r tsconfig-paths/register --project "$CLI_DIR/tsconfig.json" --transpile-only "$CLI_DIR/src/index.ts" "$@"
fi

# Check if ecosystem bundle exists in deployment location
BUNDLE_PATH="$HOME/bin/ag-ecosystem.js"

if [ ! -f "$BUNDLE_PATH" ]; then
    echo "Error: Ecosystem bundle not found at $BUNDLE_PATH"
    echo "Run: ag cli update self"
    echo ""
    echo "This will:"
    echo "  1. Rebuild the bundle from source"
    echo "  2. Deploy it to ~/bin/"
    echo "  3. Synchronize all CLI components"
    exit 1
fi

# Use ecosystem bundle for fast startup (~0.6s)
# Includes: ag query, ag sudo, ag completion, ag projects, ag doc
# Bundle is self-contained - no source project needed
exec node "$BUNDLE_PATH" "$@"
